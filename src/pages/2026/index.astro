---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, fmt } from "../../utils/time";
import { generateCalendarLinks, generateScheduleIcs } from "../../utils/calendar";

const workshopShort = "CEVENA";
const workshopTitle = "Compilation, Emulation and Verification for Neutral Atom Computing";
const conference = "IEEE Quantum Week";
const year = "2026";
const date = "September 13–18, 2026";
const location = "Toronto, Ontario, Canada";

// Calendar config (workshop date TBD within Sept 13-18; using Sept 15 as placeholder)
const calConfig = {
  title: `${workshopShort} ${year}: ${workshopTitle}`,
  location: "Metro Toronto Convention Centre, Toronto, Ontario, Canada",
  description: `Workshop at ${conference} ${year}.\n${workshopTitle}\nhttps://cevena.github.io/2026/`,
  date: "20260915",
  timezone: "America/Toronto",
  startMins: t(10, 0),
  endMins: t(16, 30),
};

const { gcalUrl, outlookUrl } = generateCalendarLinks(calConfig);

const schedule = [
  { start: t(10, 0),  end: t(10, 5),  title: "Opening Remarks", speaker: "Organizing team", abstract: "" },
  { start: t(10, 5),  end: t(10, 35), title: "Invited Talk I", speaker: "TBA", abstract: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat." },
  { start: t(10, 35), end: t(11, 5),  title: "Invited Talk II", speaker: "TBA", abstract: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum." },
  { start: t(11, 5),  end: t(11, 30), title: "Panel: Challenges in Neutral Atom Computing Software", speaker: "", abstract: "" },
  { start: t(11, 30), end: t(13, 0),  title: "Lunch", speaker: "", abstract: "" },
  { start: t(13, 0),  end: t(13, 30), title: "Invited Talk III", speaker: "TBA", abstract: "Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante." },
  { start: t(13, 30), end: t(14, 0),  title: "Invited Talk IV", speaker: "TBA", abstract: "Curabitur blandit tempus porttitor. Nullam quis risus eget urna mollis ornare vel eu leo. Donec sed odio dui. Maecenas faucibus mollis interdum." },
  { start: t(14, 0),  end: t(14, 30), title: "Break", speaker: "", abstract: "" },
  { start: t(14, 30), end: t(15, 0),  title: "Invited Talk V", speaker: "TBA", abstract: "Fusce dapibus, tellus ac cursus commodo, tortor mauris condimentum nibh, ut fermentum massa justo sit amet risus. Aenean lacinia bibendum nulla sed consectetur." },
  { start: t(15, 0),  end: t(15, 30), title: "Invited Talk VI", speaker: "TBA", abstract: "Vivamus sagittis lacus vel augue laoreet rutrum faucibus dolor auctor. Praesent commodo cursus magna, vel scelerisque nisl consectetur et. Integer posuere erat a ante venenatis dapibus posuere velit aliquet." },
  { start: t(15, 30), end: t(15, 35), title: "Break", speaker: "", abstract: "" },
  { start: t(15, 35), end: t(16, 25), title: "Panel Discussion & Open Q\u0026A", speaker: "", abstract: "" },
  { start: t(16, 25), end: t(16, 30), title: "Closing Remarks", speaker: "", abstract: "" },
];

const icsUri = generateScheduleIcs(schedule, {
  date: calConfig.date,
  timezone: calConfig.timezone,
  location: calConfig.location,
  prefix: workshopShort,
});

const organizers = [
  { name: "Xiu-Zhe Luo", affiliation: "QuEra Computing Inc.", location: "Toronto, Canada", url: "https://rogerluo.dev" },
  { name: "Rafael Haenel", affiliation: "QuEra Computing Inc.", location: "Boston, USA", url: "https://www.linkedin.com/in/rafael-haenel/" },
  { name: "Phillip Weinberg", affiliation: "QuEra Computing Inc.", location: "Boston, USA", url: "https://www.linkedin.com/in/phillip-weinberg-a8a55262/" },
  { name: "Jonathan Wurtz", affiliation: "QuEra Computing Inc.", location: "Boston, USA", url: "https://www.linkedin.com/in/jonathan-wurtz-7a4855181/" },
  { name: "Pedro Lopes", affiliation: "QuEra Computing Inc.", location: "Boston, USA", url: "https://www.linkedin.com/in/pedrolslopes/" },
  { name: "Yufei Ding", affiliation: "University of California, San Diego", location: "San Diego, USA", url: "" },
];

const breaks = new Set(["Lunch", "Break"]);
---

<BaseLayout
  title={`${workshopTitle} — ${workshopShort} ${year}`}
  description={`${workshopTitle}. A workshop at ${conference} ${year}.`}
  navBrand={workshopShort}
  navYear={year}
  navLinks={[
    { label: "About", href: "#about" },
    { label: "Schedule", href: "#schedule" },
    { label: "Organizers", href: "#organizers" },
    { label: "Venue", href: "#venue" },
  ]}
  footerText={`${workshopShort} ${year} — Workshop at ${conference}`}
  contactEmail="rluo@quera.com"
>
  <header>
    <div class="header-inner">
      <p class="header-conference"><a href="https://qce.quantum.ieee.org/2026/" target="_blank" rel="noopener noreferrer">{conference}</a></p>
      <h1 class="header-title">{workshopTitle}</h1>
      <div class="header-meta">
        <span class="header-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {date}
        </span>
        <span class="header-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {location}
        </span>
      </div>
    </div>
  </header>

  <main>
    <section id="about" class="section">
      <div class="container">
        <h2>About the Workshop</h2>
        <div class="about-content">
          <p>
            Neutral atom quantum computing has witnessed rapid progress toward utility-scale, fault-tolerant quantum computing (FTQC). As neutral atom arrays emerge as a powerful platform for quantum error correction demonstrations, the inherent flexibility of this architecture gives rise to a rich set of open problems at the software level -- spanning compilers, emulators, and programming languages.
          </p>
          <p>
            This workshop brings together software developers and researchers from across the ecosystem to exchange ideas, present new approaches, and identify key open challenges arise from neutral atom devices. Topics of focus include: (1) move compilation with arbitrary qubit moves; (2) move scheduling under fixed-lane architectures; (3) realistic emulation of neutral atom programs; and (4) programming languages and formal verification for neutral atom devices.
          </p>
          <p>
            The workshop will open with invited talks covering these topics, followed by a panel discussion with stakeholders from across the full neutral atom software stack, with the goal of advancing a shared, community-driven programming ecosystem.
          </p>
        </div>

        <h3>Key Challenges</h3>
        <div class="challenges">
          <div class="challenge">
            <h4>Lack of a converged programming model</h4>
            <p>The hardware architecture of neutral atom platforms continues to evolve rapidly, and the field has yet to converge on a standard programming model. Proposed architectures vary widely -- from zoned layouts optimized for scheduling to fixed-lane designs that simplify calibration. Recent advances such as continuous atom reloading introduce further programmability at the hardware level, leaving the execution model an open and exciting question.</p>
          </div>
          <div class="challenge">
            <h4>Move optimization as an active research frontier</h4>
            <p>A growing body of work has addressed qubit move optimization, yet the problem remains open. Emerging questions -- such as how move optimization integrates with practical error correction and how it fits within hardware-software-algorithm co-design -- are becoming prominent research directions.</p>
          </div>
          <div class="challenge">
            <h4>Scalability of emulation and verification</h4>
            <p>As hardware scales, realistic emulation and verification grow increasingly demanding. A typical error correction experiment already involves more than a hundred physical qubits; simulating such systems under realistic noise models and verifying their fidelity calls for new emulation methods that go beyond conventional approaches.</p>
          </div>
          <div class="challenge">
            <h4>Program correctness under new programming models</h4>
            <p>The high scalability and flexibility of neutral atom hardware gives rise to a highly asynchronous, parallel programming model. As programs grow in complexity, developing robust methods to verify their correctness becomes an important and largely open challenge, with clear analogies to formal verification efforts in classical software engineering.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="schedule" class="section section-alt">
      <div class="container">
        <h2>Schedule</h2>
        <div class="about-content">
          <p>
            The workshop is scheduled as a full day session for a total of approximately 4.5 hours of programming. The format is designed to balance technical depth with open community discussion. The session will feature 6 to 8 invited talks of 30 minutes each, covering the core topics of the workshop. The session will conclude with a moderated panel discussion, bringing together the invited speakers and other stakeholders from across the neutral atom software stack.
          </p>
        </div>
        <p class="section-note">Tentative schedule. All times are local ({location.split(",")[0]}).</p>
        <div class="schedule-table">
          <table>
            <thead>
              <tr>
                <th class="col-time">Time</th>
                <th class="col-duration">Duration</th>
                <th class="col-session">Session</th>
                <th class="col-speaker">Speaker</th>
              </tr>
            </thead>
            <tbody>
              {schedule.map((item) => (
                <tr class={breaks.has(item.title) ? "break-row" : ""}>
                  <td class="schedule-time">{fmt(item.start)} – {fmt(item.end)}</td>
                  <td class="schedule-duration">{item.end - item.start} min</td>
                  <td class="schedule-title">
                    {item.abstract ? (
                      <details class="talk-details">
                        <summary><span class="abstract-tag">[abstract]</span> {item.title}</summary>
                        <p class="talk-abstract">{item.abstract}</p>
                      </details>
                    ) : (
                      item.title
                    )}
                  </td>
                  <td class="schedule-speaker">{item.speaker}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="calendar-actions">
          <span class="calendar-label">Add to calendar:</span>
          <a href={gcalUrl} target="_blank" rel="noopener noreferrer">Google</a>
          <span class="calendar-sep">/</span>
          <a href={outlookUrl} target="_blank" rel="noopener noreferrer">Outlook</a>
          <span class="calendar-sep">·</span>
          <a href={icsUri} download="cevena-2026.ics">Download full schedule (.ics)</a>
        </div>
      </div>
    </section>

    <section id="organizers" class="section section-alt">
      <div class="container">
        <h2>Organizers</h2>
        <div class="organizers-grid">
          {organizers.map((org) => (
            <div class="organizer-card">
              <div class="organizer-avatar">
                <span>{org.name.charAt(0)}</span>
              </div>
              {org.url ? (
                <a href={org.url} class="organizer-name" target="_blank" rel="noopener noreferrer">{org.name}</a>
              ) : (
                <h3 class="organizer-name">{org.name}</h3>
              )}
              <p class="organizer-affiliation">{org.affiliation}</p>
              <p class="organizer-location">{org.location}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="audience" class="section">
      <div class="container">
        <h2>Target Audience</h2>
        <p>
          This workshop is intended for researchers, developers, and practitioners from both industry and academia with foundational knowledge of neutral atom quantum computing. It will be of particular interest to those working on or curious about compilation, emulation, and formal verification of neutral atom programs -- including graduate students and early-career researchers looking to engage with open problems at the software-hardware interface in the neutral atom domain.
        </p>
      </div>
    </section>

    <section id="venue" class="section">
      <div class="container">
        <h2>Venue</h2>
        <p>
          The workshop is co-located with <a href="https://qce.quantum.ieee.org/2026/" target="_blank" rel="noopener noreferrer"><strong>{conference} 2026</strong></a> at the
          Metro Toronto Convention Centre (MTCC) in {location}.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Header */
  header {
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .header-conference {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-secondary);
    margin-bottom: 1.5rem;
  }

  .header-conference a {
    color: var(--c-text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--c-border);
    transition: color 0.2s, border-color 0.2s;
  }

  .header-conference a:hover {
    color: var(--c-text);
    border-color: var(--c-text);
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--c-text);
    line-height: 1.25;
    margin-bottom: 2rem;
  }

  .header-meta {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .header-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--c-text-secondary);
    font-weight: 400;
  }

  .header-meta-item svg {
    opacity: 0.6;
  }

  /* Challenges */
  .challenges {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .challenge h4 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--c-text);
    margin-bottom: 0.4rem;
  }

  .challenge p {
    font-size: 0.9rem;
    color: var(--c-text);
    line-height: 1.7;
  }

  /* Schedule */
  .schedule-table {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  thead th {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-secondary);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--c-rule);
  }

  tbody td {
    padding: 0.65rem 0.75rem;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--c-border);
    vertical-align: top;
  }

  .col-time { width: 130px; }
  .col-duration { width: 70px; }
  .col-speaker { width: 100px; }

  .schedule-time {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    color: var(--c-text-secondary);
    font-size: 0.85rem;
  }

  .schedule-duration {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    color: var(--c-text-secondary);
    font-size: 0.85rem;
  }

  .schedule-title {
    font-weight: 500;
  }

  .talk-details summary {
    cursor: pointer;
    list-style: none;
  }

  .talk-details summary::-webkit-details-marker,
  .talk-details summary::marker {
    display: none;
    content: "";
  }

  .abstract-tag {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--c-text-secondary);
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .talk-details summary:hover .abstract-tag {
    opacity: 1;
  }

  .talk-details[open] .abstract-tag {
    opacity: 0.8;
  }

  .talk-abstract {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--c-text-secondary);
    line-height: 1.6;
    border-left: 2px solid var(--c-border);
    padding-left: 0.75rem;
  }

  .schedule-speaker {
    color: var(--c-text-secondary);
    font-style: italic;
  }

  .break-row td {
    color: var(--c-text-secondary);
    font-style: italic;
  }

  .break-row .schedule-title {
    font-weight: 400;
  }

  .calendar-actions {
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .calendar-label {
    margin-right: 0.25rem;
  }

  .calendar-sep {
    opacity: 0.4;
  }

  .calendar-actions a {
    color: var(--c-text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--c-border);
    transition: color 0.2s, border-color 0.2s;
  }

  .calendar-actions a:hover {
    color: var(--c-text);
    border-color: var(--c-text);
  }

  /* Organizers */
  .organizers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .organizer-card {
    padding: 1.25rem;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    background: var(--c-bg);
    text-align: center;
  }

  .organizer-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--c-bg-alt);
    border: 1px solid var(--c-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.75rem;
  }

  .organizer-avatar span {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--c-text-secondary);
  }

  h3.organizer-name,
  a.organizer-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.2rem;
    color: var(--c-text);
  }

  a.organizer-name {
    text-decoration: none;
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }

  a.organizer-name:hover {
    border-color: var(--c-text);
  }

  .organizer-affiliation {
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    line-height: 1.4;
  }

  .organizer-location {
    font-size: 0.78rem;
    color: var(--c-text-secondary);
    opacity: 0.7;
    margin-top: 0.1rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .header-title {
      font-size: 1.4rem;
    }

    .header-meta {
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
    }

    table {
      table-layout: auto;
    }

    .col-time { width: auto; }
    .col-duration { width: auto; }
    .col-speaker { width: auto; }

    thead { display: none; }

    tbody tr {
      display: flex;
      flex-wrap: wrap;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--c-border);
    }

    tbody td {
      border-bottom: none;
      padding: 0.1rem 0;
    }

    .schedule-time {
      width: auto;
      font-size: 0.78rem;
    }

    .schedule-duration {
      width: auto;
      font-size: 0.78rem;
    }

    .schedule-duration::before {
      content: "· ";
    }

    .schedule-title {
      width: 100%;
      font-size: 0.88rem;
    }

    .schedule-speaker {
      width: 100%;
      font-size: 0.8rem;
    }

    .organizers-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 1rem;
    }

    .calendar-actions {
      flex-wrap: wrap;
    }
  }
</style>
