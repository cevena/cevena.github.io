---
interface Props {
  title: string;
  description: string;
  navBrand: string;
  navYear: string;
  navLinks: { label: string; href: string }[];
  footerText: string;
  contactEmail: string;
}

const { title, description, navBrand, navYear, navLinks, footerText, contactEmail } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var mode = localStorage.getItem('theme') || 'system';
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var resolved = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        document.documentElement.setAttribute('data-theme', resolved);
        document.documentElement.setAttribute('data-theme-mode', mode);
      })();
    </script>
  </head>

  <body>
    <nav>
      <div class="nav-inner">
        <a href="#" class="nav-brand">{navBrand} <span class="nav-year">{navYear}</span></a>
        <div class="nav-links">
          {navLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
        <div class="nav-right">
          <button id="theme-toggle" type="button" aria-label="Toggle theme">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            <svg class="icon-system" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </button>
          <button id="menu-toggle" type="button" aria-label="Toggle menu" class="menu-toggle">
            <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="container">
        <p>{footerText}</p>
        <p class="footer-sub">Questions? Contact us at <a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle')!;
      const cycle: Record<string, string> = { light: 'dark', dark: 'system', system: 'light' };

      function applyTheme(mode: string) {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        document.documentElement.setAttribute('data-theme', resolved);
        document.documentElement.setAttribute('data-theme-mode', mode);
        if (mode === 'system') {
          localStorage.removeItem('theme');
        } else {
          localStorage.setItem('theme', mode);
        }
      }

      toggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme-mode') || 'system';
        applyTheme(cycle[current]);
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        const mode = document.documentElement.getAttribute('data-theme-mode');
        if (mode === 'system') {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      });

      const menuToggle = document.getElementById('menu-toggle')!;
      const nav = menuToggle.closest('nav')!;
      menuToggle.addEventListener('click', () => {
        nav.classList.toggle('open');
      });
      nav.querySelectorAll('.nav-links a').forEach((link) => {
        link.addEventListener('click', () => {
          nav.classList.remove('open');
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-serif: 'EB Garamond', 'Georgia', serif;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;

    --c-bg: #faf9f7;
    --c-bg-alt: #f3f1ee;
    --c-text: #2c2c2c;
    --c-text-secondary: #6b6560;
    --c-accent: #4a5568;
    --c-accent-dark: #2d3748;
    --c-border: #e2dfd9;
    --c-rule: #d4d0c8;
    --c-link: #5a4f3f;
    --c-link-hover: #3d3427;
    --c-nav-bg: rgba(250, 249, 247, 0.92);
  }

  :root[data-theme="dark"] {
    --c-bg: #1a1a1a;
    --c-bg-alt: #222120;
    --c-text: #e0ddd8;
    --c-text-secondary: #9a9590;
    --c-accent: #a0aec0;
    --c-accent-dark: #cbd5e0;
    --c-border: #333130;
    --c-rule: #3d3a37;
    --c-link: #c4b8a8;
    --c-link-hover: #e0d6c8;
    --c-nav-bg: rgba(26, 26, 26, 0.92);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--c-text);
    background: var(--c-bg);
    -webkit-font-smoothing: antialiased;
  }

  /* Navigation */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--c-nav-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--c-border);
  }

  .nav-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
  }

  .nav-brand {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-text);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .nav-year {
    font-weight: 400;
    color: var(--c-text-secondary);
    font-size: 0.95rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--c-text-secondary);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--c-text);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    padding: 0.2rem;
    cursor: pointer;
    color: var(--c-text-secondary);
  }

  .menu-toggle:hover {
    color: var(--c-text);
  }

  .icon-close { display: none; }
  nav.open .icon-menu { display: none; }
  nav.open .icon-close { display: inline; }

  #theme-toggle {
    background: none;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0.3rem 0.4rem;
    cursor: pointer;
    color: var(--c-text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, border-color 0.2s;
    line-height: 1;
  }

  #theme-toggle:hover {
    color: var(--c-text);
    border-color: var(--c-rule);
  }

  .icon-sun, .icon-moon, .icon-system { display: none; }
  :root[data-theme-mode="light"] .icon-sun { display: inline; }
  :root[data-theme-mode="dark"] .icon-moon { display: inline; }
  :root[data-theme-mode="system"] .icon-system { display: inline; }

  /* Shared section styles */
  .section {
    padding: 4rem 1.5rem;
  }

  .section-alt {
    background: var(--c-bg-alt);
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--c-text);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--c-rule);
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--c-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .section-note {
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .about-content p {
    margin-bottom: 1rem;
    color: var(--c-text);
    font-size: 0.95rem;
  }

  .section a {
    color: var(--c-link);
    text-decoration: none;
    border-bottom: 1px solid var(--c-border);
    transition: color 0.2s, border-color 0.2s;
  }

  .section a:hover {
    color: var(--c-link-hover);
    border-color: var(--c-link-hover);
  }

  /* Footer */
  footer {
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-top: 1px solid var(--c-border);
  }

  footer p {
    font-size: 0.82rem;
    color: var(--c-text-secondary);
  }

  .footer-sub {
    margin-top: 0.3rem;
    font-size: 0.78rem !important;
  }

  footer a {
    color: var(--c-link);
    text-decoration: none;
  }

  footer a:hover {
    color: var(--c-link-hover);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .menu-toggle {
      display: inline-flex;
    }

    .nav-links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0 0.25rem;
      order: 3;
    }

    nav.open .nav-links {
      display: flex;
    }

    .nav-links a {
      font-size: 0.82rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--c-border);
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .section {
      padding: 2.5rem 1rem;
    }
  }
</style>
